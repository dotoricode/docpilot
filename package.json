{
  "name": "docpilot",
  "version": "2.0.0",
  "description": "Local-first document workbench with integrated terminal and review workflows",
  "main": "main.js",
  "scripts": {
    "prestart": "npm run renderer:build",
    "start": "electron .",
    "renderer:dev": "vite --config app/vite.config.ts",
    "renderer:build": "vite build --config app/vite.config.ts",
    "renderer:typecheck": "tsc --noEmit -p app/tsconfig.json",
    "build": "npm run renderer:build && electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.docpilot.app",
    "productName": "DocPilot",
    "directories": {
      "output": "dist/package"
    },
    "asar": true,
    "asarUnpack": [
      "bridge.js",
      "adoc-worker.js",
      "store.js",
      "prompt-package.js",
      "shared/core/**",
      "scripts/fake-agent.js",
      "node_modules/node-pty/**"
    ],
    "files": [
      "main.js",
      "preload.js",
      "store.js",
      "start.html",
      "adoc-worker.js",
      "bridge.js",
      "prompt-package.js",
      "shared/**",
      "scripts/fake-agent.js",
      "dist/renderer/**",
      "assets/**",
      "!assets/*.icns"
    ],
    "mac": {
      "icon": "assets/docpilot.icns",
      "category": "public.app-category.productivity",
      "identity": "-",
      "hardenedRuntime": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "docpilot",
      "window": {
        "width": 540,
        "height": 360
      }
    }
  },
  "dependencies": {
    "@asciidoctor/core": "^2.2.9",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tiptap/markdown": "^3.27.4",
    "@tiptap/react": "^3.27.4",
    "@tiptap/starter-kit": "^3.27.4",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "highlight.js": "^11.11.1",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.3",
    "@lezer/highlight": "^1.2.3",
    "@tailwindcss/vite": "^4.3.1",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@xterm/xterm": "^6.0.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "markdown-it": "^14.2.0",
    "playwright": "^1.61.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  }
}
