{
  "name": "docpilot",
  "version": "2.0.5",
  "description": "Local-first document workbench with integrated terminal and review workflows",
  "main": "main.js",
  "scripts": {
    "prestart": "npm run renderer:build",
    "start": "electron .",
    "renderer:dev": "vite --config app/vite.config.ts",
    "renderer:build": "vite build --config app/vite.config.ts",
    "renderer:typecheck": "tsc --noEmit -p app/tsconfig.json",
    "test": "node --test tests/*.test.js",
    "check:shutdown": "DOCPILOT_TEST_HIDDEN_WINDOWS=1 node scripts/check-shutdown-lifecycle.js",
    "check:terminal:create": "DOCPILOT_TEST_HIDDEN_WINDOWS=1 node scripts/check-react-terminal-creation.js",
    "check:terminal:narrow": "npm run renderer:build && DOCPILOT_TEST_HIDDEN_WINDOWS=1 node scripts/check-react-terminal-narrow-layout.js",
    "check:toc": "npm run renderer:build && DOCPILOT_TEST_HIDDEN_WINDOWS=1 node scripts/check-react-toc-navigation.js",
    "check:pane-drag": "npm run renderer:build && DOCPILOT_TEST_HIDDEN_WINDOWS=1 node scripts/check-react-pane-drag-drop.js",
    "check:update-flow": "npm run renderer:build && DOCPILOT_TEST_HIDDEN_WINDOWS=1 node scripts/check-react-update-preservation.js",
    "check:update-manual": "npm run renderer:build && DOCPILOT_TEST_HIDDEN_WINDOWS=1 node scripts/check-react-manual-update.js",
    "check:preview-workflows": "npm run renderer:build && DOCPILOT_TEST_HIDDEN_WINDOWS=1 node scripts/check-react-preview-workflows.js",
    "check:markdown-source-preservation": "npm run renderer:build && DOCPILOT_TEST_HIDDEN_WINDOWS=1 node scripts/check-react-markdown-source-preservation.js",
    "check:markdown-document": "npm run renderer:build && DOCPILOT_TEST_HIDDEN_WINDOWS=1 node scripts/check-react-markdown-document.js",
    "check:markdown-keyboard-layout": "npm run renderer:build && DOCPILOT_TEST_HIDDEN_WINDOWS=1 node scripts/check-react-markdown-document-keyboard-layout.js",
    "check:renderer-security": "npm run renderer:build && DOCPILOT_TEST_HIDDEN_WINDOWS=1 node scripts/check-react-asciidoc-security.js",
    "manual:verify": "node scripts/check-manual-v2-orca-parity.mjs && node scripts/check-manual-v2-changelog-evidence.mjs && node scripts/check-manual-v2-demo-playback.mjs && npm --prefix prototypes/manual-v2 run build",
    "manual:pages:stage": "npm --prefix prototypes/manual-v2 run build:pages && rsync -a prototypes/manual-v2/dist/ docs/",
    "manual:vercel:link": "npx --yes vercel@56.3.1 link --yes --project docpilot-manual --scope wpfhks-projects",
    "manual:vercel:preview": "npx --yes vercel@56.3.1 deploy --yes --project docpilot-manual --scope wpfhks-projects",
    "manual:vercel:production": "npx --yes vercel@56.3.1 deploy --prod --yes --project docpilot-manual --scope wpfhks-projects",
    "manual:verify:public": "node scripts/check-public-manual.mjs",
    "build": "npm run renderer:build && electron-builder --mac"
  },
  "build": {
    "appId": "com.docpilot.app",
    "productName": "DocPilot",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist/package"
    },
    "asar": true,
    "asarUnpack": [
      "bridge.js",
      "adoc-worker.js",
      "store.js",
      "prompt-package.js",
      "shared/core/**",
      "scripts/fake-agent.js",
      "node_modules/node-pty/**",
      "node_modules/@asciidoctor/core/**",
      "node_modules/asciidoctor-opal-runtime/**",
      "node_modules/unxhr/**",
      "node_modules/highlight.js/**",
      "node_modules/fast-glob/**",
      "node_modules/@nodelib/**",
      "node_modules/run-parallel/**",
      "node_modules/queue-microtask/**",
      "node_modules/fastq/**",
      "node_modules/reusify/**",
      "node_modules/glob-parent/**",
      "node_modules/is-glob/**",
      "node_modules/is-extglob/**",
      "node_modules/merge2/**",
      "node_modules/micromatch/**",
      "node_modules/braces/**",
      "node_modules/fill-range/**",
      "node_modules/to-regex-range/**",
      "node_modules/is-number/**",
      "node_modules/picomatch/**"
    ],
    "files": [
      "main.js",
      "preload.js",
      "store.js",
      "start.html",
      "adoc-worker.js",
      "bridge.js",
      "prompt-package.js",
      "shared/**",
      "THIRD_PARTY_NOTICES.md",
      "scripts/fake-agent.js",
      "dist/renderer/**",
      "assets/**",
      "!assets/*.icns",
      "!assets/*.icon/**"
    ],
    "mac": {
      "icon": "assets/docpilot.icon",
      "category": "public.app-category.productivity",
      "identity": "-",
      "hardenedRuntime": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "docpilot",
      "icon": "assets/docpilot.icns",
      "window": {
        "width": 540,
        "height": 360
      }
    }
  },
  "dependencies": {
    "@asciidoctor/core": "^2.2.9",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/noto-sans-kr": "^5.2.10",
    "@phosphor-icons/react": "^2.1.10",
    "@sanity/diff-match-patch": "3.2.0",
    "@tiptap/extension-code-block-lowlight": "3.27.4",
    "@tiptap/extension-image": "3.27.4",
    "@tiptap/extension-link": "3.27.4",
    "@tiptap/extension-list": "3.27.4",
    "@tiptap/extension-mathematics": "3.27.4",
    "@tiptap/extension-table": "3.27.4",
    "@tiptap/markdown": "3.27.4",
    "@tiptap/react": "3.27.4",
    "@tiptap/starter-kit": "3.27.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "dompurify": "^3.4.12",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.577.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.3",
    "@lezer/highlight": "^1.2.3",
    "@tailwindcss/vite": "^4.3.1",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@xterm/xterm": "^6.0.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "markdown-it": "^14.2.0",
    "playwright": "^1.61.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  }
}
